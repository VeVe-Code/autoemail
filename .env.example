PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/test_user_provisioner
DEFAULT_DELAY_MIN_MS=700
DEFAULT_DELAY_MAX_MS=2200

# Plesk (XML-RPC)
DOMAIN=example.com
PLESK_HOST=https://your-plesk-host:8443
PLESK_PACKET_VERSION=1.6.9.1

# Optional: if set, skips domain->site-id lookup
# PLESK_SITE_ID=123

# Auth mode: plain (username/password) OR key (API secret key)
PLESK_AUTH_METHOD=plain
PLESK_USERNAME=admin
# If password contains '#', quote it in .env (this project strips quotes safely)
PLESK_PASSWORD="change-me"

# If using key auth:
# PLESK_AUTH_METHOD=key
# PLESK_KEY=your-secret-key

PLESK_MAX_RETRIES=3
PLESK_RETRY_BASE_DELAY_MS=500
