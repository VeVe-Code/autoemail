{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app.js": {
      "maxDuration": 60,
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/src/app.js" },
    { "source": "/health", "destination": "/src/app.js" }
  ]
}
